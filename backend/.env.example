# Gemini API configuration
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_CHAT_ENDPOINT=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent?key=YOUR_GEMINI_API_KEY
GEMINI_EMBEDDINGS_ENDPOINT=https://generativelanguage.googleapis.com/v1beta/models/gemini-embedding-001:embedContent?key=YOUR_GEMINI_API_KEY
# Optional comma-separated fallback models
# GEMINI_CHAT_FALLBACK_MODELS=gemini-2.5-pro,gemini-1.5-flash

# Qdrant vector database
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your_qdrant_api_key
QDRANT_COLLECTION_NAME=documents

# CORS — comma-separated allowed origins
CORS_ORIGINS=http://localhost:5173

# Confluence API configuration (optional — used for document ingestion)
CONFLUENCE_BASE_URL=https://yourinstance.atlassian.net/wiki
CONFLUENCE_USERNAME=your_email@example.com
CONFLUENCE_API_TOKEN=your_confluence_api_token
